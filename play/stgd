/* ====== DRAW ====== */
function draw(){
  ctx.save();
  ctx.translate(Math.round(G.shX),Math.round(G.shY));
  ctx.fillStyle='#000';ctx.fillRect(-16,-16,W+32,H+32);

  for(const s of G.stars){
    const a=s.a*(1+Math.sin(Date.now()*.001+s.phase)*.3);
    ctx.globalAlpha=a;ctx.fillStyle='#fff';ctx.fillRect(s.x,s.y,s.r,s.r);
  }
  ctx.globalAlpha=1;

  for(const p of G.pus){
    const c=p.type==='power'?'rgba(80,200,255,.85)':p.type==='bomb'?'rgba(255,150,40,.85)':'rgba(255,160,210,.9)';
    const s=4+Math.sin(p.t*.12)*.6;
    ctx.strokeStyle=c;ctx.lineWidth=1.4;
    ctx.beginPath();ctx.moveTo(p.x-s,p.y);ctx.lineTo(p.x+s,p.y);ctx.stroke();
    ctx.beginPath();ctx.moveTo(p.x,p.y-s);ctx.lineTo(p.x,p.y+s);ctx.stroke();
    ctx.beginPath();ctx.moveTo(p.x,p.y-s*.7);ctx.lineTo(p.x+s*.7,p.y);ctx.lineTo(p.x,p.y+s*.7);ctx.lineTo(p.x-s*.7,p.y);ctx.closePath();ctx.stroke();
  }

  for(const c of G.convertPts){
    const a=c.life/32;ctx.globalAlpha=a*.8;
    ctx.fillStyle='rgba(255,255,120,1)';
    const r=3*(1-a)+1;
    ctx.beginPath();ctx.arc(c.x,c.y,r,0,Math.PI*2);ctx.fill();
  }
  ctx.globalAlpha=1;

  for(const p of G.parts){
    const a=p.life/p.maxLife;
    if(p.type==='dot'){ctx.globalAlpha=a*.88;ctx.fillStyle=p.c;ctx.beginPath();ctx.arc(p.x,p.y,p.r*a,0,Math.PI*2);ctx.fill();}
    else if(p.type==='ring'){ctx.globalAlpha=a*.65;ctx.strokeStyle=p.c;ctx.lineWidth=1.5;ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.stroke();}
  }
  ctx.globalAlpha=1;

  for(const r of G.grazeRings){
    const a=r.life/r.maxLife;ctx.globalAlpha=a*.55;ctx.strokeStyle='rgba(255,255,160,.9)';ctx.lineWidth=1;
    ctx.beginPath();ctx.arc(r.x,r.y,r.r,0,Math.PI*2);ctx.stroke();
  }
  ctx.globalAlpha=1;

  drawEnemies();
  drawBoss();

  for(const b of G.pB){
    const alpha=b.c.includes('rgba')?.5:1;
    ctx.globalAlpha=alpha;
    ctx.fillStyle='#aaccff';ctx.fillRect(b.x-1.5,b.y-3,3,7);
    ctx.fillStyle='#fff';ctx.fillRect(b.x-1,b.y-2,2,5);
  }
  ctx.globalAlpha=1;

  drawEnemyBullets();

  if(G.invuln%4<2||G.invuln===0)drawPlayer();

  if(inp.slow){
    ctx.strokeStyle='rgba(255,255,255,.16)';ctx.lineWidth=1;
    ctx.beginPath();ctx.arc(G.px+12,G.py+12,12,0,Math.PI*2);ctx.stroke();
    ctx.fillStyle='rgba(255,80,80,.95)';
    ctx.beginPath();ctx.arc(G.px+12,G.py+12,2.2,0,Math.PI*2);ctx.fill();
    const lv=Math.min(4,Math.floor(G.power/80));
    if(lv>=2){for(const sx of[-20,20]){ctx.fillStyle='rgba(180,200,255,.35)';ctx.beginPath();ctx.arc(G.px+12+sx,G.py+6,3.5,0,Math.PI*2);ctx.fill();}}
  }

  if(G.flashA>0){ctx.globalAlpha=G.flashA;ctx.fillStyle='#fff';ctx.fillRect(0,0,W,H);ctx.globalAlpha=1;}

  ctx.restore();
  drawInGameMessages();
}

function drawEnemies(){
  for(const e of G.ens){
    const col=e.flash>0?'rgba(255,255,255,.9)':e.pals[0].ball;
    ctx.save();ctx.translate(e.x+e.w/2,e.y+e.h/2);
    ctx.strokeStyle=col;ctx.lineWidth=1.2;ctx.globalAlpha=.7;
    ctx.beginPath();ctx.arc(0,0,e.w*.58,0,Math.PI*2);ctx.stroke();
    ctx.rotate(e.formTimer*.03);ctx.globalAlpha=1;
    ctx.strokeStyle=col;ctx.lineWidth=1.3;
    ctx.strokeRect(-e.w/2,-e.h/2,e.w,e.h);
    ctx.rotate(-e.formTimer*.055);
    ctx.fillStyle=e.pals[1]?e.pals[1].core:'#fff';ctx.globalAlpha=.7;
    ctx.beginPath();ctx.arc(0,0,e.w*.24,0,Math.PI*2);ctx.fill();
    ctx.globalAlpha=1;ctx.restore();
    if(e.hp<e.maxHp){ctx.fillStyle='rgba(255,255,255,.05)';ctx.fillRect(e.x,e.y-5,e.w,2);ctx.fillStyle=e.pals[0].ball;ctx.fillRect(e.x,e.y-5,e.w*(e.hp/e.maxHp),2);}
  }
  ctx.globalAlpha=1;
}

function drawBoss(){
  const b=G.boss;if(!b||b.y<-b.h)return;
  const bc=b.flash>0?'rgba(255,255,255,.85)':'rgba(255,255,255,.92)';
  if(b.spellPhase&&b.currentSpell>=0){
    const pal=PALETTE[PAL_KEYS[b.currentSpell%PAL_KEYS.length]];
    const pulse=.12+Math.sin(b.anim*2.4)*.08;
    ctx.globalAlpha=pulse;ctx.fillStyle=pal.ball;
    ctx.beginPath();ctx.arc(b.x+b.w/2,b.y+b.h/2,b.w/2+24+Math.sin(b.anim)*8,0,Math.PI*2);ctx.fill();
    for(let r=0;r<2;r++){
      const ra=b.w/2+18+r*16+Math.sin(b.anim*(1+r*.5))*5;
      ctx.globalAlpha=(.08-r*.03)+Math.sin(b.anim+r)*.03;
      ctx.strokeStyle=pal.ball;ctx.lineWidth=1+r*.5;
      ctx.beginPath();ctx.arc(b.x+b.w/2,b.y+b.h/2,ra,0,Math.PI*2);ctx.stroke();
    }
    ctx.globalAlpha=1;
  }
  ctx.strokeStyle=bc;ctx.lineWidth=2;
  ctx.beginPath();ctx.arc(b.x+b.w/2,b.y+b.h/2,b.w/2,0,Math.PI*2);ctx.stroke();
  ctx.save();ctx.translate(b.x+b.w/2,b.y+b.h/2);
  ctx.rotate(b.anim*.8);ctx.strokeStyle=bc;ctx.lineWidth=1.8;
  ctx.strokeRect(-b.w*.44,-b.h*.44,b.w*.88,b.h*.88);
  ctx.rotate(b.anim*.4+Math.PI/4);ctx.globalAlpha=.5;
  ctx.strokeRect(-b.w*.3,-b.h*.3,b.w*.6,b.h*.6);
  ctx.globalAlpha=1;ctx.restore();
  // スペル名をCanvas内に描画（ボス頭上）
  if(b.spellPhase&&b.currentSpell>=0){
    const sp=SPELL_CARDS[b.currentSpell];
    ctx.textAlign='center';ctx.fillStyle='rgba(255,220,80,.45)';ctx.font='.38rem \'Shippori Mincho\'';
    ctx.textBaseline='bottom';ctx.fillText(sp.name,b.x+b.w/2,b.y-8);
  }
  ctx.textBaseline='alphabetic';
}

function drawEnemyBullets(){
  for(const b of G.eB){
    if(b.delay>0)continue;
    const a=b.dead?Math.max(0,b.r/9):.88;
    if(a<=0)continue;
    ctx.globalAlpha=a;
    const x=b.x,y=b.y,r=b.r;
    switch(b.type){
      case'ball':
        ctx.fillStyle=b.c;ctx.beginPath();ctx.arc(x,y,r,0,Math.PI*2);ctx.fill();
        ctx.fillStyle=b.cc||'#fff';ctx.beginPath();ctx.arc(x-r*.28,y-r*.28,r*.38,0,Math.PI*2);ctx.fill();
        break;
      case'large':{
        const lg=ctx.createRadialGradient(x,y,r*.2,x,y,r);
        lg.addColorStop(0,b.cc||'#fff');lg.addColorStop(0.5,b.c);lg.addColorStop(1,'rgba(0,0,0,0)');
        ctx.fillStyle=lg;ctx.beginPath();ctx.arc(x,y,r*1.3,0,Math.PI*2);ctx.fill();
        ctx.fillStyle=b.cc||'#fff';ctx.beginPath();ctx.arc(x,y,r*.35,0,Math.PI*2);ctx.fill();
        break;}
      case'bubble':
        ctx.strokeStyle=b.c;ctx.lineWidth=1.5;ctx.beginPath();ctx.arc(x,y,r,0,Math.PI*2);ctx.stroke();
        ctx.fillStyle=b.cc||'#fff';ctx.globalAlpha=a*.3;ctx.beginPath();ctx.arc(x-r*.32,y-r*.32,r*.32,0,Math.PI*2);ctx.fill();ctx.globalAlpha=a;
        break;
      case'rice':{
        const ang=Math.atan2(b.vy,b.vx)+b.rot;
        ctx.save();ctx.translate(x,y);ctx.rotate(ang);
        ctx.fillStyle=b.c;ctx.beginPath();ctx.ellipse(0,0,r*2.4,r*.72,0,0,Math.PI*2);ctx.fill();
        ctx.fillStyle=b.cc||'#fff';ctx.globalAlpha=a*.7;ctx.beginPath();ctx.ellipse(-r*.3,0,r*.85,r*.24,0,0,Math.PI*2);ctx.fill();
        ctx.restore();break;}
      case'knife':{
        const ang=Math.atan2(b.vy,b.vx);
        ctx.save();ctx.translate(x,y);ctx.rotate(ang);
        const kg=ctx.createLinearGradient(-r*1.6,0,r*3.2,0);
        kg.addColorStop(0,'rgba(0,0,0,0)');kg.addColorStop(0.3,b.c);kg.addColorStop(1,b.cc||'#fff');
        ctx.fillStyle=kg;ctx.beginPath();ctx.moveTo(r*3.2,0);ctx.lineTo(-r*1.6,r*.65);ctx.lineTo(-r*1.6,-r*.65);ctx.closePath();ctx.fill();
        ctx.strokeStyle=b.cc||'#fff';ctx.lineWidth=.6;ctx.globalAlpha=a*.5;
        ctx.beginPath();ctx.moveTo(r*3.0,0);ctx.lineTo(-r*1.4,r*.55);ctx.stroke();
        ctx.beginPath();ctx.moveTo(r*3.0,0);ctx.lineTo(-r*1.4,-r*.55);ctx.stroke();
        ctx.restore();break;}
      case'star':{
        ctx.save();ctx.translate(x,y);ctx.rotate(b.rot);
        ctx.fillStyle=b.c;ctx.globalAlpha=a*.4;ctx.beginPath();ctx.arc(0,0,r*1.3,0,Math.PI*2);ctx.fill();ctx.globalAlpha=a;
        ctx.fillStyle=b.c;ctx.beginPath();
        for(let i=0;i<5;i++){const a0=(Math.PI*2/5)*i-Math.PI/2;const a1=a0+Math.PI/5;if(i===0)ctx.moveTo(Math.cos(a0)*r,Math.sin(a0)*r);else ctx.lineTo(Math.cos(a0)*r,Math.sin(a0)*r);ctx.lineTo(Math.cos(a1)*r*.42,Math.sin(a1)*r*.42);}
        ctx.closePath();ctx.fill();
        ctx.fillStyle=b.cc||'#fff';ctx.globalAlpha=a*.8;ctx.beginPath();ctx.arc(0,0,r*.28,0,Math.PI*2);ctx.fill();
        ctx.restore();break;}
      case'oval':{
        const ang=Math.atan2(b.vy,b.vx)+b.rot;
        ctx.save();ctx.translate(x,y);ctx.rotate(ang+Math.PI/2);
        ctx.fillStyle=b.c;ctx.beginPath();ctx.ellipse(0,0,r*.65,r*1.5,0,0,Math.PI*2);ctx.fill();
        ctx.fillStyle=b.cc||'#fff';ctx.globalAlpha=a*.6;ctx.beginPath();ctx.ellipse(-r*.18,0,r*.22,r*.55,0,0,Math.PI*2);ctx.fill();
        ctx.restore();break;}
      default:
        ctx.fillStyle=b.c;ctx.beginPath();ctx.arc(x,y,r,0,Math.PI*2);ctx.fill();
    }
  }
  ctx.globalAlpha=1;
}

function drawPlayer(){
  const x=G.px,y=G.py;
  const lv=Math.min(4,Math.floor(G.power/80));
  const col=(G.charDef||CHAR_DEFS[0]).col;
  const[cr,cg,cb]=hexToRgb(col);
  ctx.fillStyle=`rgba(${cr},${cg},${cb},${.1+lv*.025})`;
  ctx.beginPath();ctx.moveTo(x+12,y+22);ctx.lineTo(x+4,y+28);ctx.lineTo(x+12,y+24);ctx.lineTo(x+20,y+28);ctx.closePath();ctx.fill();
  ctx.fillStyle='#ffffff';ctx.globalAlpha=.85+lv*.03;
  ctx.beginPath();ctx.moveTo(x+12,y+1);ctx.lineTo(x+22,y+20);ctx.lineTo(x+12,y+15);ctx.lineTo(x+2,y+20);ctx.closePath();ctx.fill();
  if(lv>=2){ctx.fillStyle=`rgba(${cr},${cg},${cb},.6)`;for(const sx of[-18,18]){ctx.beginPath();ctx.arc(x+12+sx,y+13,3.5,0,Math.PI*2);ctx.fill();}}
  if(lv>=4){ctx.fillStyle=`rgba(${cr},${cg},${cb},.4)`;for(const sx of[-28,28]){ctx.beginPath();ctx.arc(x+12+sx,y+16,3,0,Math.PI*2);ctx.fill();}}
  ctx.globalAlpha=1;
}

/* インゲームメッセージはCanvasに直接描画 */
function drawInGameMessages(){
  ctx.textBaseline='middle';
  // combo
  if(G.combo>1){
    const intensity=G.combo>=100?.95:G.combo>=50?.8:G.combo>=20?.62:.44;
    ctx.textAlign='center';ctx.fillStyle=`rgba(255,255,255,${intensity})`;
    ctx.font=`300 ${G.combo>=50?.68:.58}rem 'DM Mono'`;
    ctx.fillText(G.combo+' COMBO',W/2,H*.34);
  }
  if(G.msg.t){
    const a=Math.min(1,G.msg.f/12);
    ctx.textAlign='center';ctx.globalAlpha=a;ctx.fillStyle='rgba(255,215,106,.9)';
    ctx.font='300 .64rem \'Shippori Mincho\'';
    ctx.fillText(G.msg.t,W/2,H*.44);ctx.globalAlpha=1;
  }
  if(G.banner.t){
    const a=Math.min(1,G.banner.f/18);
    ctx.textAlign='center';ctx.globalAlpha=a;ctx.fillStyle='rgba(255,255,255,.9)';
    ctx.font=`300 ${Math.max(19.2,Math.min(30.4,H*.032))}px 'Shippori Mincho'`;
    ctx.fillText(G.banner.t,W/2,H*.48);ctx.globalAlpha=1;
  }
  if(G.state==='warn'){
    const p=.36+Math.sin(Date.now()/160)*.46;
    ctx.textAlign='center';ctx.globalAlpha=p;ctx.fillStyle='rgba(255,55,35,1)';
    ctx.font=`300 ${Math.max(16,Math.min(27.2,H*.028))}px 'DM Mono'`;
    ctx.fillText('WARNING',W/2,H*.48);ctx.globalAlpha=1;
  }
  // ステージ進行バー（ボスなし時）
  if(!G.boss&&G.state!=='warn'){
    const pct=Math.max(0,1-G.stageF/(K.STAGE_SEC*60));
    ctx.fillStyle='rgba(255,255,255,.03)';ctx.fillRect(0,H-2,W,2);
    ctx.fillStyle='rgba(255,215,106,.25)';ctx.fillRect(0,H-2,W*pct,2);
  }
  ctx.textBaseline='alphabetic';
}

function shake(m,d){if(!cfg.shake)return;G.shF=d;G.shX=(Math.random()-.5)*m*2;G.shY=(Math.random()-.5)*m*2;}
function showMsg(t,ms){G.msg={t,f:Math.round(ms/(1000/60))};}
function showBanner(t){G.banner={t,f:120};}

function refreshSysBar(){
  const bar=$('sys-bar');
  ['play','warn','clear','countdown'].includes(G.state)?bar.classList.add('dim'):bar.classList.remove('dim');
}
function popScore(x,y,pts,mult){
  const playArea=$('play-area');
  const el=document.createElement('div');
  const col=mult>=3?'rgba(255,220,80,.8)':mult>=1.5?'rgba(180,240,255,.75)':'rgba(255,255,255,.55)';
  el.style.cssText=`position:absolute;pointer-events:none;z-index:9;font-family:'DM Mono',monospace;font-size:.56rem;color:${col};left:${x-20}px;top:${y}px;animation:sp .85s ease-out forwards`;
  el.textContent='+'+pts.toLocaleString()+(mult>1.02?' ×'+mult.toFixed(1):'');
  playArea.appendChild(el);setTimeout(()=>el.remove(),860);
  if(!$('sp-s')){const s=document.createElement('style');s.id='sp-s';s.textContent='@keyframes sp{0%{opacity:.7;transform:translateY(0)}100%{opacity:0;transform:translateY(-38px)}}';document.head.appendChild(s);}
}

/* 入力 */
const inp={up:false,down:false,left:false,right:false,slow:false};

function setupInput(){
  const KM={ArrowLeft:'left',ArrowRight:'right',ArrowUp:'up',ArrowDown:'down',KeyA:'left',KeyD:'right',KeyW:'up',KeyS:'down'};
  document.addEventListener('keydown',G._kd=e=>{
    if(G.state!=='play')return;
    if(KM[e.code]){e.preventDefault();inp[KM[e.code]]=true;}
    if(e.code==='KeyX'||e.code==='Space'){e.preventDefault();useBomb(false);}
    if(e.code==='ShiftLeft'||e.code==='ShiftRight'){e.preventDefault();inp.slow=true;}
    if(e.code==='Escape'||e.code==='KeyP')pauseGame();
  });
  document.addEventListener('keyup',G._ku=e=>{
    if(KM[e.code])inp[KM[e.code]]=false;
    if(e.code==='ShiftLeft'||e.code==='ShiftRight')inp.slow=false;
  });
}

function removeInput(){
  if(G._kd){document.removeEventListener('keydown',G._kd);G._kd=null;}
  if(G._ku){document.removeEventListener('keyup',G._ku);G._ku=null;}
  inp.slow=false;
}

let setReturnTo='o-start';
function pauseGame(){if(G.state!=='play')return;G.state='pause';show('o-pause');refreshSysBar();}
function resumeGame(){hide('o-pause');G.state='countdown';refreshSysBar();startCountdown(()=>{G.state='play';refreshSysBar();});}

let _raf=null;
function loop(){if(G.state==='dead'){_raf=null;return;}update();draw();_raf=requestAnimationFrame(loop);}
function teardown(){if(_raf){cancelAnimationFrame(_raf);_raf=null;}removeInput();}

function gameStart(){
  if(!G.charDef){G.charDef=CHAR_DEFS[0];G.weapon=CHAR_DEFS[0].weapons[0].id;}
  Sfx.init();resetG();placePlayer();setupInput();
  G.state='countdown';refreshSysBar();
  $('hud-boss-area').style.display='none';
  updateHUD();
  if(!_raf)loop();
  startCountdown(()=>{G.state='play';showBanner('STAGE 1');G.formF=80;refreshSysBar();});
}

function renderCharSelect(){
  const el=$('char-list');el.innerHTML='';
  CHAR_DEFS.forEach((c,i)=>{
    const b=document.createElement('button');
    b.className='cw-row'+(i===0?' sel':'');
    b.innerHTML=`<span class="nm"><span class="cw-dot" style="background:${c.col}"></span>${c.name}　<span style="opacity:.45;font-size:.85em">${c.title}</span></span>`;
    b.onclick=()=>{renderWeaponSelect(i);show('o-weapon');};
    b.addEventListener('mouseenter',()=>setSel('o-char',i));
    el.appendChild(b);
  });
  resetMenuIdx('o-char');
}
function renderWeaponSelect(ci){
  hide('o-char');
  const c=CHAR_DEFS[ci];
  $('weapon-char-name').innerHTML=`<span class="cw-dot" style="background:${c.col}"></span>${c.name} ・ ${c.title}`;
  const el=$('weapon-list');el.innerHTML='';
  c.weapons.forEach((w,i)=>{
    const b=document.createElement('button');
    b.className='cw-row'+(i===0?' sel':'');
    b.innerHTML=`<span class="nm">${w.name}</span><span class="ds">${w.desc}</span>`;
    b.onclick=()=>{G.charDef=c;G.weapon=w.id;hide('o-weapon');gameStart();};
    b.addEventListener('mouseenter',()=>setSel('o-weapon',i));
    el.appendChild(b);
  });
  resetMenuIdx('o-weapon');
}

const OPT_ROWS=[
  {key:'difficulty',label:'難易度',type:'cycle',values:['easy','normal','hard'],labels:['EASY','NORMAL','HARD']},
  {key:'sound',label:'サウンド',type:'bool'},
  {key:'scorePop',label:'スコア表示',type:'bool'},
  {key:'shake',label:'画面シェイク',type:'bool'},
];
function optValText(row){
  if(row.type==='bool')return cfg[row.key]?'ON':'OFF';
  const idx=row.values.indexOf(cfg[row.key]);return row.labels[idx<0?0:idx];
}
function cycleOption(idx,dir){
  const row=OPT_ROWS[idx];
  if(row.type==='bool')cfg[row.key]=!cfg[row.key];
  else{let i=row.values.indexOf(cfg[row.key]);i=(i<0?0:i)+dir;if(i<0)i=row.values.length-1;if(i>=row.values.length)i=0;cfg[row.key]=row.values[i];}
  Store.saveCfg(cfg);
  if(row.key==='sound')refreshSfxBtn();
  renderSettings(false);
}
function renderSettings(reset){
  const el=$('opt-rows');el.innerHTML='';
  OPT_ROWS.forEach((row,i)=>{
    const d=document.createElement('div');
    d.className='opt-row'+(i===0&&reset!==false?' sel':(menuSel.overlay==='o-set'&&menuSel.idx===i?' sel':''));
    d.innerHTML=`<span class="opt-label">${row.label}</span><span class="opt-value"><span class="arrow l">◀</span><span class="val-text">${optValText(row)}</span><span class="arrow r">▶</span></span>`;
    d.querySelector('.arrow.l').onclick=ev=>{ev.stopPropagation();setSel('o-set',i);cycleOption(i,-1);};
    d.querySelector('.arrow.r').onclick=ev=>{ev.stopPropagation();setSel('o-set',i);cycleOption(i,1);};
    d.onclick=()=>{setSel('o-set',i);cycleOption(i,1);};
    d.addEventListener('mouseenter',()=>setSel('o-set',i));
    el.appendChild(d);
  });
  if(reset!==false)resetMenuIdx('o-set');
}
function refreshSfxBtn(){Sfx.on=cfg.sound;}

function renderHS(){
  const el=$('hs-list');
  if(!hs.length){el.innerHTML='<div class="pr" style="justify-content:center;color:rgba(255,255,255,.35);font-size:.56rem;letter-spacing:.2em">記録なし</div>';return;}
  el.innerHTML=hs.map((s,i)=>`<div class="pr"><span class="k">${i+1}位　ST.${s.stage}</span><span class="v">${s.score.toLocaleString()}</span></div>`).join('');
}

let cfg=Store.loadCfg();
let hs=Store.loadHS();

window.addEventListener('load',()=>{
  // 強制全画面：ロード直後に試みる（ユーザー操作なしでは拒否される場合あり）
  const tryFullscreen=()=>{
    const el=document.documentElement;
    if(!document.fullscreenElement){
      (el.requestFullscreen?.()
        ||el.webkitRequestFullscreen?.()
        ||el.mozRequestFullScreen?.()
        ||Promise.resolve()).catch(()=>{});
    }
  };
  // 一部ブラウザはload時に直接呼べる。呼べない場合は最初のユーザー操作で実行
  tryFullscreen();
  document.addEventListener('click',tryFullscreen,{once:true});
  document.addEventListener('keydown',tryFullscreen,{once:true});
  resize();let rt;window.addEventListener('resize',()=>{clearTimeout(rt);rt=setTimeout(resize,80);});
  refreshSfxBtn();
  setSel('o-start',0);
  const au=()=>{Sfx.init();};
  document.addEventListener('click',au,{once:true});
  $('b-start').onclick=()=>{hide('o-start');renderCharSelect();show('o-char');};
  $('b-char-back').onclick=()=>{hide('o-char');show('o-start');};
  $('b-weapon-back').onclick=()=>{hide('o-weapon');renderCharSelect();show('o-char');};
  $('b-hs').onclick=()=>{renderHS();hide('o-start');show('o-hs');};
  $('b-set').onclick=()=>{setReturnTo='o-start';hide('o-start');renderSettings();show('o-set');};
  $('b-set-back').onclick=()=>{hide('o-set');show(setReturnTo);};
  $('b-hs-back').onclick=()=>{hide('o-hs');show('o-start');};
  $('b-hs-clr').onclick=()=>{if(confirm('ハイスコアを削除しますか？')){Store.clearHS();hs=[];renderHS();}};
  const pH=e=>{e.preventDefault();pauseGame();};
  $('sp').addEventListener('click',pH);
  $('b-resume').onclick=resumeGame;
  $('b-pause-opt').onclick=()=>{setReturnTo='o-pause';hide('o-pause');renderSettings();show('o-set');};
  $('b-quit').onclick=()=>location.reload();
  $('b-retry').onclick=()=>location.reload();
  refreshSysBar();
  // ハイスコア初期表示
  const topScore=hs.length?hs[0].score:0;
  $('hud-hiscore').textContent=topScore.toLocaleString();
  (function idle(){if(G.state!=='menu')return;tickStars();draw();requestAnimationFrame(idle);})();
});
</script>
