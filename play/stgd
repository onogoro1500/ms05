/* BULLET FACTORY */
function mkB(x,y,vx,vy,pal,type,ax,ay,delay){
  const b=bGet();
  b.x=x;b.y=y;b.vx=vx;b.vy=vy;
  b.ax=ax||0;b.ay=ay||0;
  b.delay=delay||0;
  b.c=pal.ball;b.cc=pal.core;b.rim=pal.rim;
  b.type=type||'ball';
  b.dead=false;b.grazed=false;b.homing=false;b.str=0;b.age=0;b.rot=0;b.rotSpd=0;
  b.curl=0;b.accel=1;b.waveAmp=0;b.waveFreq=0;b.wavePhase=0;
  b.r=type==='large'?9:type==='oval'?7:type==='star'?5.5:type==='rice'?4:type==='knife'?3:type==='bubble'?8:5;
  return b;
}

function addCurlBullet(x,y,speed,angle,curl,pal,type,delay){
  const b=mkB(x,y,Math.cos(angle)*speed,Math.sin(angle)*speed,pal,type||'ball',0,0,delay||0);
  b.curl=curl||0;
  return b;
}
function addAccelBullet(x,y,speed,angle,accel,pal,type,delay){
  const b=mkB(x,y,Math.cos(angle)*speed,Math.sin(angle)*speed,pal,type||'ball',0,0,delay||0);
  b.accel=accel||1;
  return b;
}
function addWaveBullet(x,y,vx,vy,waveAmp,waveFreq,wavePhase,pal,type){
  const b=mkB(x,y,vx,vy,pal,type||'ball');
  b.waveAmp=waveAmp;b.waveFreq=waveFreq;b.wavePhase=wavePhase||0;
  return b;
}

