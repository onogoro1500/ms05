const menuSel={overlay:null,idx:0};
function getMenuItems(id){
  switch(id){
    case 'o-start':return [$('b-start'),$('b-hs'),$('b-set')];
    case 'o-char':return Array.from($('char-list').children);
    case 'o-weapon':return Array.from($('weapon-list').children);
    case 'o-set':return Array.from($('opt-rows').children).concat([$('b-set-back')]);
    case 'o-hs':return [$('b-hs-clr'),$('b-hs-back')];
    case 'o-pause':return [$('b-resume'),$('b-pause-opt'),$('b-quit')];
    case 'o-result':return [$('b-retry')];
    default:return [];
  }
}
function setSel(id,idx){
  const items=getMenuItems(id);if(!items.length)return;
  if(idx<0)idx=items.length-1;if(idx>=items.length)idx=0;
  items.forEach(it=>it&&it.classList.remove('sel'));
  if(items[idx])items[idx].classList.add('sel');
  menuSel.overlay=id;menuSel.idx=idx;
}
function resetMenuIdx(id){setSel(id,0);}
function onShowOverlay(id){
  if(id==='o-hs'){setSel('o-hs',1);return;}
  if(['o-start','o-pause','o-result'].includes(id))resetMenuIdx(id);
}
function moveSel(dir){
  const id=menuSel.overlay;if(!id)return;
  setSel(id,menuSel.idx+dir);
}
function activateSel(){
  const id=menuSel.overlay;if(!id)return;
  const items=getMenuItems(id);const it=items[menuSel.idx];
  if(it)it.click();
}
function backSel(){
  const id=menuSel.overlay;
  if(id==='o-char')$('b-char-back').click();
  else if(id==='o-weapon')$('b-weapon-back').click();
  else if(id==='o-set')$('b-set-back').click();
  else if(id==='o-hs')$('b-hs-back').click();
  else if(id==='o-pause')$('b-resume').click();
}
function leftRightSel(dir){
  if(menuSel.overlay==='o-set'){
    const items=getMenuItems('o-set');
    if(menuSel.idx<OPT_ROWS.length)cycleOption(menuSel.idx,dir);
  }
}
document.addEventListener('keydown',e=>{
  if(G.state==='play')return;
  if(!['o-start','o-char','o-weapon','o-set','o-hs','o-pause','o-result'].includes(menuSel.overlay))return;
  if(e.code==='ArrowUp'){e.preventDefault();moveSel(-1);}
  else if(e.code==='ArrowDown'){e.preventDefault();moveSel(1);}
  else if(e.code==='ArrowLeft'){e.preventDefault();leftRightSel(-1);}
  else if(e.code==='ArrowRight'){e.preventDefault();leftRightSel(1);}
  else if(e.code==='KeyZ'||e.code==='Enter'){e.preventDefault();activateSel();}
  else if(e.code==='KeyX'||e.code==='Escape'){e.preventDefault();backSel();}
});
