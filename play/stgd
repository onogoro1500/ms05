/* レイアウト：プレイエリアを常に縦長4:3（width:height=3:4）に固定。
   ウィンドウの形に関わらず、高さ基準でプレイエリア幅を算出し、
   HUDパネルを含めた全体幅がウィンドウ幅を超える場合は全体を均等に縮小する。 */
const root=$('root'),playAreaEl=$('play-area'),hudPanelEl=$('hud-panel');
const PLAY_RATIO=3/4; // width / height
function layoutGame(){
  const vw=window.innerWidth,vh=window.innerHeight;
  let playH=vh,playW=playH*PLAY_RATIO;
  let hudW=Math.min(320,Math.max(130,playW/3));
  let totalW=playW+hudW;
  if(totalW>vw){
    const s=vw/totalW;
    playH*=s;playW*=s;hudW*=s;
  }
  root.style.width=(playW+hudW)+'px';
  root.style.height=playH+'px';
  playAreaEl.style.flex='0 0 '+playW+'px';
  hudPanelEl.style.flex='0 0 '+hudW+'px';
  hudPanelEl.style.minWidth='0';
  hudPanelEl.style.maxWidth='none';
}

/* CANVAS */
const cv=$('cv');
const ctx=cv.getContext('2d',{alpha:false});
let W=0,H=0;
function resize(){
  layoutGame();
  const dpr=Math.min(window.devicePixelRatio||1,3);
  const r=cv.getBoundingClientRect();
  cv.width=Math.round(r.width*dpr);cv.height=Math.round(r.height*dpr);
  W=r.width;H=r.height;
  ctx.setTransform(dpr,0,0,dpr,0,0);
  G.stars=mkStars();
}

