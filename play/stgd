    if(G.spellTimer%8===0){const a0=angle(ex,ey,G.px+12,G.py+12);const b=mkB(ex,ey,Math.cos(a0)*5.2*s,Math.sin(a0)*5.2*s,PALETTE.yellow,'knife');G.eB.push(b);}
    G.spA+=.28;
  },
  hellfireCross(ex,ey,s){
    for(let dir=0;dir<4;dir++){const baseA=dir*Math.PI/2+G.spA*.1;for(let i=0;i<5;i++){const a=baseA+(i-2)*.12;const b=mkB(ex,ey,Math.cos(a)*(2.2+i*.3)*s,Math.sin(a)*(2.2+i*.3)*s,[PALETTE.orange,PALETTE.red,PALETTE.yellow][dir%3],'ball');b.delay=i*4;G.eB.push(b);}}
    if(G.spellTimer%26===0){const N=16;for(let i=0;i<N;i++){const a=(Math.PI*2/N)*i+G.spA;const sp=1.6*s;const pal=i%2===0?PALETTE.red:PALETTE.yellow;const b=mkB(ex,ey,Math.cos(a)*sp,Math.sin(a)*sp,pal,'star');b.rotSpd=.06;G.eB.push(b);}}
    G.spA+=.15;
  },
  musouTensei(ex,ey,s){
    const N=16;
    for(let ring=0;ring<2;ring++){for(let i=0;i<N;i++){const a=(Math.PI*2/N)*i+G.spA*(ring===0?1:-1);const sp=(ring===0?2.2:1.5)*s;const pal=[PALETTE.white,PALETTE.cyan][ring];const b=mkB(ex,ey,Math.cos(a)*sp,Math.sin(a)*sp,pal,ring===0?'rice':'ball');b.rotSpd=(ring===0?.03:-.04);G.eB.push(b);}}
    const a0=angle(ex,ey,G.px+12,G.py+12);
    for(let i=-1;i<=1;i++){const b=mkB(ex,ey,Math.cos(a0+i*.2)*5.5*s,Math.sin(a0+i*.2)*5.5*s,PALETTE.gold,'knife');G.eB.push(b);}
    G.spA+=.21;
  },
  butterflyBanquet(ex,ey,s){
    const px=G.px+12,py=G.py+12;const a0=angle(ex,ey,px,py);
    for(let wing=0;wing<2;wing++){const sign=wing===0?1:-1;for(let i=0;i<6;i++){const a=a0+sign*(0.2+i*.1);const sp=(2.4+i*.22)*s;const b=addCurlBullet(ex,ey,sp,a,-sign*.022*s,[PALETTE.pink,PALETTE.purple,PALETTE.cyan][i%3],'rice',i*4);G.eB.push(b);}}
    if(G.spellTimer%18===0){const N=10;for(let i=0;i<N;i++){const a=a0+Math.PI+(i/N-0.5)*2.2;const b=mkB(ex,ey,Math.cos(a)*3.2*s,Math.sin(a)*3.2*s,PALETTE.white,'ball');G.eB.push(b);}}
    G.spA+=.18;
  },
  thunderVortex(ex,ey,s){
    const ARMS=5;
    for(let arm=0;arm<ARMS;arm++){const a=G.spA+(Math.PI*2/ARMS)*arm;const sp=2.5*s;const b=addCurlBullet(ex,ey,sp,a,.02*s,PALETTE.yellow,'ball');G.eB.push(b);const b2=addCurlBullet(ex,ey,sp*.7,a+.35,-.025*s,PALETTE.gold,'rice');G.eB.push(b2);}
    if(G.spellTimer%12===0){for(let i=0;i<3;i++){const bx=ex+(Math.random()-.5)*180;const b=mkB(bx,K.TOP+10,(Math.random()-.5)*.8,4.5*s,PALETTE.silver,'knife');b.delay=i*4;G.eB.push(b);}}
    G.spA+=.2;
  },
  chaosRebellion(ex,ey,s){
    const pals=[PALETTE.red,PALETTE.cyan,PALETTE.yellow,PALETTE.purple,PALETTE.green];
    const types=['ball','rice','star','large','oval','knife'];
    for(let arm=0;arm<5;arm++){const a=G.spA+(Math.PI*2/5)*arm;const pal=pals[arm];const type=types[arm];const b=addAccelBullet(ex,ey,1.5*s,a,1.018,pal,type);G.eB.push(b);}
    if(G.spellTimer%16===0){const a0=angle(ex,ey,G.px+12,G.py+12);for(let i=-2;i<=2;i++){G.eB.push(mkB(ex,ey,Math.cos(a0+i*.14)*5*s,Math.sin(a0+i*.14)*5*s,PALETTE.white,'knife'));}}
    if(G.spellTimer%9===0){const a=rnd(Math.PI*2);const b=addWaveBullet(ex,ey,Math.cos(a)*2.2*s,Math.sin(a)*2.2*s,20,0.15,rnd(Math.PI*2),pals[G.spellTimer%5],'bubble');G.eB.push(b);}
    G.spA+=.14;
  },
  eternalLoop(ex,ey,s){
    for(let ring=0;ring<3;ring++){const N=8;const dir=ring%2===0?1:-1;for(let i=0;i<N;i++){const a=(Math.PI*2/N)*i+G.spA*dir+(ring*Math.PI*2/3);const pal=[PALETTE.pink,PALETTE.cyan,PALETTE.gold][ring];const b=addCurlBullet(ex,ey,(1.8+ring*.5)*s,a,dir*.016*(ring+1),pal,'ball',i*3);G.eB.push(b);}}
    const a0=angle(ex,ey,G.px+12,G.py+12);
    for(let i=-2;i<=2;i++){G.eB.push(mkB(ex,ey,Math.cos(a0+i*.1)*5.8*s,Math.sin(a0+i*.1)*5.8*s,PALETTE.white,'knife'));}
    if(G.spellTimer%15===0){for(let side=0;side<2;side++){const b=addWaveBullet(side===0?-10:W+10,ey+rnd(80)-40,(side===0?2.4:-2.4)*s,0,25,0.2,G.spellTimer*.1,PALETTE.purple,'oval');G.eB.push(b);}}
    G.spA+=.12;
  },
  lastResort(ex,ey,s){
    for(let ring=0;ring<4;ring++){const N=8;const dir=ring%2===0?1:-1;for(let i=0;i<N;i++){const a=(Math.PI*2/N)*i+G.spA*dir+(ring*Math.PI/2);const pal=[PALETTE.red,PALETTE.cyan,PALETTE.yellow,PALETTE.purple][ring];const b=addCurlBullet(ex,ey,(1.5+ring*.4)*s,a,dir*.02,pal,'ball',ring*5+i*2);G.eB.push(b);}}
    const a0=angle(ex,ey,G.px+12,G.py+12);
    for(let i=-3;i<=3;i++){G.eB.push(mkB(ex,ey,Math.cos(a0+i*.1)*5.8*s,Math.sin(a0+i*.1)*5.8*s,PALETTE.gold,'knife'));}
    if(G.spellTimer%14===0){for(let i=0;i<3;i++){const b=addWaveBullet(rnd(W),K.TOP+8,0,2.2*s,15,0.18,i*1.2,PALETTE.white,'large');b.homing=true;b.str=.022*s;b.delay=i*6;G.eB.push(b);}}
    G.spA+=.1;
  },
};

function doNormalShoot(key,ex,ey,pals,s){
  const px=G.px+12,py=G.py+12;
  const pal=pals[Math.floor(rnd(pals.length))];
  const pal2=pals[1]||pal;
  switch(key){
    case'radial':for(let i=0;i<8;i++){const a=(Math.PI*2/8)*i+G.spA;G.eB.push(mkB(ex,ey,Math.cos(a)*2.4*s,Math.sin(a)*2.4*s,pal,'ball'));}G.spA+=.24;break;
    case'aimed3':{const a=angle(ex,ey,px,py);for(let i=-1;i<=1;i++){G.eB.push(mkB(ex,ey,Math.cos(a+i*.2)*3.2*s,Math.sin(a+i*.2)*3.2*s,pal,'rice'));}break;}
    case'aimed5':{const a=angle(ex,ey,px,py);for(let i=-2;i<=2;i++){G.eB.push(mkB(ex,ey,Math.cos(a+i*.18)*2.8*s,Math.sin(a+i*.18)*2.8*s,pal,'ball'));}break;}
    case'spread':for(let i=-3;i<=3;i++){G.eB.push(mkB(ex,ey,i*1.1*s,2.8*s,pal,'ball'));}break;
    case'homing':{const b=mkB(ex,ey,0,1.8*s,pal,'large');b.homing=true;b.str=.055*s;G.eB.push(b);break;}
    case'spiral':for(let i=0;i<3;i++){const a=G.spA+(Math.PI*2/3)*i;G.eB.push(mkB(ex,ey,Math.cos(a)*2.6*s,Math.sin(a)*2.6*s,pal,'ball'));}G.spA+=.38;break;
    case'knife_aimed':{const a=angle(ex,ey,px,py);G.eB.push(mkB(ex,ey,Math.cos(a)*5*s,Math.sin(a)*5*s,pal,'knife'));G.eB.push(mkB(ex,ey,Math.cos(a+.18)*4.5*s,Math.sin(a+.18)*4.5*s,pal,'knife'));G.eB.push(mkB(ex,ey,Math.cos(a-.18)*4.5*s,Math.sin(a-.18)*4.5*s,pal,'knife'));break;}
    case'curve_shot':{for(let i=0;i<6;i++){const a=angle(ex,ey,px,py)+(i-2.5)*.15;const sign=i%2===0?1:-1;const b=addCurlBullet(ex,ey,2.8*s,a,sign*.024,pal,'rice');b.delay=i*4;G.eB.push(b);}break;}
    case'wave_shot':{for(let i=0;i<3;i++){const a=Math.PI/2+(i-1)*.5;const b=addWaveBullet(ex,ey,Math.cos(a)*2.2*s,Math.sin(a)*2.2*s,22,0.14,i*1.0,i===1?pal:pal2,'oval');b.delay=i*8;G.eB.push(b);}break;}
    case'accel_shot':{const a=angle(ex,ey,px,py);for(let i=0;i<9;i++){const b=addAccelBullet(ex,ey,1.2*s+i*.3,a+(i-1.5)*.15,1.032,pal,'ball',i*6);G.eB.push(b);}break;}
    case'fan_burst':{const a=angle(ex,ey,px,py);for(let i=0;i<6;i++){const b=mkB(ex,ey,Math.cos(a+(i-3)*.16)*2.2*s,Math.sin(a+(i-3)*.16)*2.2*s,i%2===0?pal:pal2,i===0||i===6?'knife':'ball');b.delay=Math.abs(i-3)*3;G.eB.push(b);}break;}
    case'orbit_aimed':{for(let i=0;i<6;i++){const a=(Math.PI*2/6)*i+G.spA;G.eB.push(mkB(ex,ey,Math.cos(a)*2.0*s,Math.sin(a)*2.0*s,pal,'star'));}const a0=angle(ex,ey,px,py);G.eB.push(mkB(ex,ey,Math.cos(a0)*4.8*s,Math.sin(a0)*4.8*s,pal2,'knife'));G.spA+=.3;break;}
  }
}

