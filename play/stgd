function mkStars(){
  return Array.from({length:70},()=>({
    x:rnd(W),y:rnd(H),r:.5+rnd(1.2),vy:.2+rnd(1.8),a:.015+rnd(.1),phase:rnd(Math.PI*2),
  }));
}

function placePlayer(){G.px=W/2-12;G.py=H-K.BOT-70;G.invuln=60;}

function spawnFormation(){
  const f=FORMATIONS[rndi(0,FORMATIONS.length)];
  const stageScale=Math.min(G.stage,BOSS_DEFS.length);
  const pools=[
    ['radial','aimed3','wave_shot'],['aimed3','aimed5','curve_shot'],
    ['spread','homing','accel_shot'],['aimed5','spiral','fan_burst'],
    ['homing','knife_aimed','orbit_aimed'],['knife_aimed','spiral','curve_shot'],
  ];
  const pool=pools[Math.min(stageScale-1,pools.length-1)];
  for(let i=0;i<f.count;i++){
    const init=f.fn(i,f.count);
    if(!init)continue; // フォーメーション中の「抜け道」枠
    const pals=[rPal(),rPal()];
    const tKey=pool[i%pool.length];
    const t=E_TYPES.find(e=>e.key===tKey)||E_TYPES[0];
    const hp=t.hp+Math.floor((stageScale-1)*.6);
    G.ens.push({
      key:t.key,w:t.w,h:t.h,hp,maxHp:hp,sc:t.sc,pals,
      x:init.x-t.w/2,y:init.y,vx:init.vx,vy:init.vy,
      role:init.role,arcDir:init.arcDir||1,phase:init.phase!==undefined?init.phase:rnd(Math.PI*2),
      targetX:init.targetX!==undefined?init.targetX:W/2,
      spiralR:init.spiralR!==undefined?init.spiralR:40,
      baseX:init.x,formTimer:0,cd:K.E_CD,flash:0,
    });
    G.spawned++;
  }
  G.formF=rndi(170,320)-stageScale*14;
}

