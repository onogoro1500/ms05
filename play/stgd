function tickParts(){
  for(let i=G.parts.length-1;i>=0;i--){
    const p=G.parts[i];p.life--;
    if(p.life<=0){pRet(G.parts.splice(i,1)[0]);continue;}
    if(p.type==='dot'){p.x+=p.vx;p.y+=p.vy;p.vy+=.04;p.vx*=.97;}
    else if(p.type==='ring'){p.r+=4.5;}
  }
  for(let i=G.grazeRings.length-1;i>=0;i--){
    const r=G.grazeRings[i];r.life--;r.r+=2;if(r.life<=0)G.grazeRings.splice(i,1);
  }
}

function activateSpell(idx){
  G.spellActive=true;G.spellIdx=idx;G.spellTimer=0;
  const sp=SPELL_CARDS[idx];
  G.spellBonus=sp.bonus||50000;
  G.spellBonusInit=G.spellBonus;
  $('spell-title').textContent=sp.name;
  $('spell-sub').textContent=sp.sub;
  const el=$('spell-banner');
  el.style.opacity='1';setTimeout(()=>{el.style.opacity='0';},2400);
  $('spell-timer-bar').style.display='block';
  $('spell-timer-fill').style.background='rgba(255,220,80,.7)';
  $('spell-timer-fill').style.width='100%';
  $('spell-timer-fill').style.transition='none';
  setTimeout(()=>{
    $('spell-timer-fill').style.transition='width '+((sp.time/60).toFixed(1))+'s linear';
    $('spell-timer-fill').style.width='0%';
  },50);
  convertBullets();
  Sfx.spell();
}

function endSpellPhase(b){
  if(!b.spellPhase)return;
  b.spellPhase=false;
  b.cardsRemaining=Math.max(0,(b.cardsRemaining||0)-1);
  $('spell-timer-bar').style.display='none';
}

function convertBullets(){
  const pts=300;let count=0;
  for(const b of G.eB){if(!b.dead){G.convertPts.push({x:b.x,y:b.y,life:32});b.dead=true;count++;}}
  if(count>0){G.score+=pts*count;if(cfg.scorePop)popScore(W/2,H*.38,pts*count,1);Sfx.convert();}
}

function triggerWarn(){
  G.state='warn';G.warnF=K.WARN_F;
  G.eB.forEach(b=>b.dead=true);
  showMsg('WARNING',9999);shake(12,80);Sfx.warn();
}

function spawnBoss(){
  const def=BOSS_DEFS[(G.stage-1)%BOSS_DEFS.length];
  G.boss={...def,x:W/2-def.w/2,y:-def.h-50,maxHp:def.hp,ph:0,
    spellPhase:false,currentSpell:-1,spellCooldown:0,
    spellTimeLeft:0,spellFailed:false,
    cardsRemaining:def.spells.length,
    sCD:40,mt:0,anim:0,flash:0,
    usedSpells:new Set()};
  G.state='play';G.warnF=0;G.ens=[];G.msg={t:'',f:0};
  $('spell-timer-bar').style.display='none';
  const si=def.spells[0];
  G.boss.currentSpell=si;
  G.boss.usedSpells.add(si);
  G.boss.spellPhase=true;
  G.boss.spellTimeLeft=SPELL_CARDS[si].time;
  G.boss.spellFailed=false;
  activateSpell(si);
  showMsg(def.name,2500);Sfx.boss();
  // HUDボスエリア表示
  updateBossHUD();
}

function update(){
  if(G.state==='pause'||G.state==='dead'||G.state==='countdown')return;
  if(G.shF>0){G.shF--;if(!G.shF){G.shX=0;G.shY=0;}}
  if(G.flashA>0)G.flashA=Math.max(0,G.flashA-.05);
  if(G.msg.f>0){G.msg.f--;if(!G.msg.f)G.msg.t='';}
  if(G.banner.f>0){G.banner.f--;if(!G.banner.f)G.banner.t='';}
  if(G.deathbombF>0)G.deathbombF--;
  for(let i=G.convertPts.length-1;i>=0;i--){G.convertPts[i].life--;if(G.convertPts[i].life<=0)G.convertPts.splice(i,1);}
  if(G.state==='warn'){if(--G.warnF<=0)spawnBoss();tickStars();tickBullets();tickParts();return;}
  if(G.state==='clear'){if(++G.clearF>150)finishClear();tickStars();tickBullets();tickParts();return;}
  tickPlayer();tickStage();tickEnemies();tickBoss();
  tickBullets();tickPickups();checkCols();tickStars();tickParts();
  if(G.bombCD>0)G.bombCD--;
  if(G.combo>0&&++G.comboF>=K.COMBO_DEC){G.combo=Math.max(0,G.combo-1);G.comboF=0;}
  // HUD更新
  updateHUD();
}

function tickPlayer(){
  const cd=G.charDef||CHAR_DEFS[0];
  const spd=inp.slow?cd.focusSpd:cd.spd;
  if(inp.left)G.px-=spd;if(inp.right)G.px+=spd;
  if(inp.up)G.py-=spd;if(inp.down)G.py+=spd;
  G.px=clamp(G.px,0,W-24);G.py=clamp(G.py,K.TOP,H-24-K.BOT);
  if(G.invuln>0)G.invuln--;
  const now=Date.now();
  if(now-G.lastFire>K.FIRE_MS){playerShoot();G.lastFire=now;}
}

function playerShoot(){
  const lv=Math.min(4,Math.floor(G.power/80));
  const cx=G.px+12;
  const wide=G.weapon==='wide';
  const foc=inp.slow;
  const spacing=(wide?9:6)*(foc?.42:1);
  const angScale=(wide?.5:.32)*(foc?.3:1);
  for(let i=-lv;i<=lv;i++){
    const b=bGet();b.x=cx+i*spacing;b.y=G.py;b.vx=i*angScale;b.vy=-15;
    b.r=3;b.c='#fff';b.cc='#fff';b.rim='#88aaff';b.homing=false;b.grazed=false;b.dead=false;
    b.type='knife';b.age=0;b.ax=0;b.ay=0;b.delay=0;b.rot=0;b.rotSpd=0;
    b.curl=0;b.accel=1;b.waveAmp=0;b.waveFreq=0;b.wavePhase=0;
    G.pB.push(b);
  }
  if(lv>=2){
    const off=((wide?26:18)*(foc?.45:1))+(wide?4:0);
    for(const sx of[-off,off]){
      const b=bGet();b.x=cx+sx;b.y=G.py+6;b.vx=(sx>0?1:-1)*(wide?.9:.6)*(foc?.35:1);b.vy=-12;
      b.r=2.5;b.c='rgba(160,180,255,.55)';b.cc='#aabbff';b.rim='#fff';b.homing=false;b.grazed=false;b.dead=false;
      b.type='ball';b.age=0;b.ax=0;b.ay=0;b.delay=0;b.rot=0;b.rotSpd=0;
      b.curl=0;b.accel=1;b.waveAmp=0;b.waveFreq=0;b.wavePhase=0;
      G.pB.push(b);
    }
  }
  if(lv>=4&&G.lastFire%160<20){
    const b=bGet();b.x=cx;b.y=G.py+4;b.vx=0;b.vy=-9;
    b.r=4;b.c='rgba(200,220,255,.7)';b.cc='#ccddff';b.rim='#aabbff';b.homing=true;b.str=.08;b.grazed=false;b.dead=false;
    b.type='ball';b.age=0;b.ax=0;b.ay=0;b.delay=0;b.rot=0;b.rotSpd=0;
    b.curl=0;b.accel=1;b.waveAmp=0;b.waveFreq=0;b.wavePhase=0;
    G.pB.push(b);
  }
  Sfx.shoot();
}

function tickStage(){
  if(G.boss||G.state==='warn')return;
  G.stageF++;
  if(--G.formF<=0)spawnFormation();
  if(G.stageF>=K.STAGE_SEC*60&&!G.ens.length)triggerWarn();
}

function tickEnemies(){
  for(let i=G.ens.length-1;i>=0;i--){
    const e=G.ens[i];
    e.formTimer++;
    if(e.flash>0)e.flash--;
    switch(e.role){
      case'follow_sine':e.y+=e.vy*G.diffMult*G.spdMult;e.x=e.baseX+Math.sin(e.formTimer*.025+e.phase)*40;break;
      case'follow_arc':e.y+=e.vy*G.diffMult*G.spdMult;e.x+=e.arcDir*Math.cos(e.phase*.012)*1.8*G.diffMult;e.phase++;break;
      case'converge':e.y+=e.vy*G.diffMult*G.spdMult;e.x=lerp(e.x,e.targetX,.02*G.diffMult);break;
      case'spiral':e.y+=e.vy*G.diffMult*G.spdMult;e.x=e.baseX+Math.cos(e.formTimer*.045+e.phase)*e.spiralR;break;
      case'dive_lock':e.x+=e.vx*G.diffMult*G.spdMult;e.y+=e.vy*G.diffMult*G.spdMult;break;
      case'hold':default:e.x+=e.vx*G.diffMult*G.spdMult;e.y+=e.vy*G.diffMult*G.spdMult;if(e.y>100){e.vy=lerp(e.vy,.32,.04);e.vx=lerp(e.vx,0,.03);}break;
    }
    if(--e.cd<=0){doNormalShoot(e.key,e.x+e.w/2,e.y+e.h/2,e.pals,K.BSPD*G.spdMult);e.cd=K.E_CD+rnd(K.E_CDV);}
    if(e.y>H+100||e.x<-120||e.x>W+120)G.ens.splice(i,1);
  }
}

function tickBoss(){
  const b=G.boss;if(!b)return;
  if(b.y<82)b.y+=1.8;
  else{b.mt+=.015;b.x=W/2-b.w/2+Math.sin(b.mt)*90+Math.sin(b.mt*1.7)*28;}
  b.anim+=.04;
  if(b.flash>0)b.flash--;
  if(b.spellPhase&&b.spellTimeLeft>0){
    b.spellTimeLeft--;
    const sp=SPELL_CARDS[b.currentSpell];
    if(!b.spellFailed){G.spellBonus=Math.max(0,Math.round(G.spellBonusInit*(b.spellTimeLeft/sp.time)));}
    if(b.spellTimeLeft<=0){
      if(!b.spellFailed){b.spellFailed=true;G.spellBonus=0;showMsg('TIME UP',1500);$('spell-timer-fill').style.background='rgba(255,80,60,.7)';}
      endSpellPhase(b);
    }
  }
  const pct=b.hp/b.maxHp*100;
  const ph=BOSS_DEFS[(G.stage-1)%BOSS_DEFS.length].phases;
  const np=ph.length>1&&pct<=ph[1].pct?1:0;
  if(np!==b.ph){
    b.ph=np;
    if(b.spellPhase){
      if(!b.spellFailed&&G.spellBonus>0){G.totalSpellBonus+=G.spellBonus;G.score+=G.spellBonus;if(cfg.scorePop)popScore(W/2,H*.35,G.spellBonus,1);showMsg('SPELL BONUS! +'+G.spellBonus.toLocaleString(),1800);Sfx.spellBonus();}
      endSpellPhase(b);
    }
    const def=BOSS_DEFS[(G.stage-1)%BOSS_DEFS.length];
    const availSpells=def.spells.filter(idx=>!b.usedSpells.has(idx));
    if(availSpells.length>0){
      const si=availSpells[0];b.currentSpell=si;b.usedSpells.add(si);b.spellPhase=true;b.spellTimeLeft=SPELL_CARDS[si].time;b.spellFailed=false;activateSpell(si);b.sCD=50;
    }
    shake(10,18);G.flashA=.3;spawnParts(b.x+b.w/2,b.y+b.h/2,'#ffffff',18,4,28);Sfx.phase();
  }
  if(--b.sCD<=0){
    if(b.y>0){
      const ex=b.x+b.w/2,ey=b.y+b.h/2;
      if(b.spellPhase&&b.currentSpell>=0){G.spellTimer++;const fn=SPELL_CARDS[b.currentSpell].fn;if(SpellFire[fn])SpellFire[fn](ex,ey,K.BSPD*G.spdMult);}
      else{const def=BOSS_DEFS[(G.stage-1)%BOSS_DEFS.length];const pat=def.phases[b.ph].pat;doNormalShoot(pat[Math.floor(G.stageF/80)%pat.length],ex,ey,[rPal(),rPal()],K.BSPD*G.spdMult);}
    }
    const def=BOSS_DEFS[(G.stage-1)%BOSS_DEFS.length];const cp=def.phases[b.ph];b.sCD=cp.cd[0]+rnd(cp.cd[1]-cp.cd[0]);
  }
  updateBossHUD();
}

function tickBullets(){
  const px=G.px+12,py=G.py+12;
  for(const b of G.pB){
    if(b.homing){
      let bx=W/2,by=K.TOP+50;let bd=999;
      for(const e of G.ens){const ex=e.x+e.w/2,ey=e.y+e.h/2,d2=(ex-b.x)**2+(ey-b.y)**2;if(d2<bd){bd=d2;bx=ex;by=ey;}}
      if(G.boss&&G.boss.y>0){bx=G.boss.x+G.boss.w/2;by=G.boss.y+G.boss.h/2;}
      const dx=bx-b.x,dy=by-b.y,d=Math.sqrt(dx*dx+dy*dy);
      if(d>5){b.vx+=dx/d*b.str;b.vy+=dy/d*b.str;}
    }
    b.x+=b.vx;b.y+=b.vy;b.age++;
  }
  for(const b of G.eB){
    if(b.dead){b.r=Math.max(0,b.r-.35);continue;}
    b.age++;
    if(b.delay>0){b.delay--;continue;}
    if(b.homing){const dx=px-b.x,dy=py-b.y,d=Math.sqrt(dx*dx+dy*dy);if(d>5){b.vx+=dx/d*b.str;b.vy+=dy/d*b.str;const sp=Math.sqrt(b.vx*b.vx+b.vy*b.vy),mx=4.2*K.BSPD;if(sp>mx){b.vx=b.vx/sp*mx;b.vy=b.vy/sp*mx;}}}
    if(b.curl!==0){const cos=Math.cos(b.curl),sin=Math.sin(b.curl);const nvx=b.vx*cos-b.vy*sin;const nvy=b.vx*sin+b.vy*cos;b.vx=nvx;b.vy=nvy;}
    if(b.accel!==1){const spd=Math.sqrt(b.vx*b.vx+b.vy*b.vy);const newSpd=Math.min(spd*b.accel,8);if(spd>0.01){b.vx=b.vx/spd*newSpd;b.vy=b.vy/spd*newSpd;}}
    if(b.waveAmp!==0){const spd=Math.sqrt(b.vx*b.vx+b.vy*b.vy);if(spd>0.01){const nx=-b.vy/spd,ny=b.vx/spd;const wave=Math.sin(b.age*b.waveFreq+b.wavePhase)*b.waveAmp*.04;b.x+=nx*wave;b.y+=ny*wave;}}
    b.vx+=b.ax;b.vy+=b.ay;
    if(b.rotSpd)b.rot+=b.rotSpd;
    b.x+=b.vx;b.y+=b.vy;
  }
  for(let i=G.pB.length-1;i>=0;i--)if(G.pB[i].y<-40||G.pB[i].x<-40||G.pB[i].x>W+40)bRet(G.pB.splice(i,1)[0]);
  for(let i=G.eB.length-1;i>=0;i--){const b=G.eB[i];if((b.dead&&b.r<=0)||b.y>H+90||b.y<-90||b.x<-90||b.x>W+90)bRet(G.eB.splice(i,1)[0]);}
}

function tickPickups(){
  const px=G.px+12,py=G.py+12;
  const autoCol=G.py<H*.22;
  for(const p of G.pus){
    const dx=px-p.x,dy=py-p.y,d=Math.sqrt(dx*dx+dy*dy);
    if(autoCol||d<180){p.x+=dx/d*7;p.y+=dy/d*7;}else p.y+=1.8;
    p.t++;
  }
  G.pus=G.pus.filter(p=>p.y<H+28);
}

function tickStars(){
  const slow=inp.slow;
  for(const s of G.stars){s.y+=s.vy*(slow?.55:1);if(s.y>H+4){s.y=-4;s.x=rnd(W);}}
}

function checkCols(){
  for(let i=G.pB.length-1;i>=0;i--){
    const pb=G.pB[i];let hit=false;
    for(let j=G.ens.length-1;!hit&&j>=0;j--){
      const e=G.ens[j];
      if(pb.x>e.x&&pb.x<e.x+e.w&&pb.y>e.y&&pb.y<e.y+e.h){
        e.hp--;e.flash=3;hit=true;
        if(e.hp<=0){
          const mult=Math.min(1+G.combo*.08,K.COMBO_MAX);
          G.score+=Math.floor(e.sc*mult);G.combo++;if(G.combo>G.maxCombo)G.maxCombo=G.combo;
          G.comboF=0;G.killed++;G.power=Math.min(K.MAX_POW,G.power+K.POW_K);
          if(Math.random()<K.DROP)G.pus.push({x:e.x+e.w/2,y:e.y,type:Math.random()<.65?'power':(Math.random()<.85?'bomb':'extend'),t:0});
          if(cfg.scorePop)popScore(e.x+e.w/2,e.y,Math.floor(e.sc*mult),mult);
          spawnParts(e.x+e.w/2,e.y+e.h/2,e.pals[0].ball,10,3,18);
          spawnRing(e.x+e.w/2,e.y+e.h/2,e.pals[0].ball);
          G.ens.splice(j,1);Sfx.explode();
        }
      }
    }
    if(!hit&&G.boss&&G.boss.y>0){
      const b=G.boss;
      if(pb.x>b.x&&pb.x<b.x+b.w&&pb.y>b.y&&pb.y<b.y+b.h){
        b.hp-=DIFF[cfg.difficulty].bDmg;b.flash=3;hit=true;
        if(b.spellPhase&&!b.spellFailed){b.spellFailed=true;G.spellBonus=0;showMsg('SPELL FAILED',1000);}
        spawnParts(pb.x,pb.y,PALETTE.white.ball,2,2,8);
        if(b.hp<=0)bossDown();
      }
    }
    if(hit)bRet(G.pB.splice(i,1)[0]);
  }

  if(G.invuln<=0){
    const px=G.px+12,py=G.py+12;
    const hr=inp.slow?K.HIT_S:K.HIT_N;
    for(let i=G.eB.length-1;i>=0;i--){
      const b=G.eB[i];if(b.dead||b.delay>0)continue;
      const dx=b.x-px,dy=b.y-py,d2=dx*dx+dy*dy;
      if(d2<(hr+b.r)*(hr+b.r)){
        if(G.deathbombF>0&&G.bombs>0){G.deathbombF=0;useBomb(true);bRet(G.eB.splice(i,1)[0]);Sfx.deathbomb();$('deathbomb-flash').style.background='rgba(255,200,80,.45)';setTimeout(()=>{$('deathbomb-flash').style.background='rgba(255,200,80,0)';},100);continue;}
        onHit();bRet(G.eB.splice(i,1)[0]);continue;
      }
      const gr=K.GRAZE_R*((G.charDef||CHAR_DEFS[0]).graze)+b.r;
      if(!b.grazed&&d2<gr*gr){b.grazed=true;G.graze++;G.score+=K.GRAZE_PT;spawnGrazeRing(px,py);Sfx.graze();}
      if(b.grazed&&d2>=gr*gr*1.6)b.grazed=false;
    }
    for(const e of G.ens)if(G.px+12>e.x&&G.px+12<e.x+e.w&&G.py+12>e.y&&G.py+12<e.y+e.h)onHit();
  }

  const px=G.px+12,py=G.py+12;
  const oldPow=Math.floor(G.power/80);
  for(let i=G.pus.length-1;i>=0;i--){
    const p=G.pus[i];const dx=p.x-px,dy=p.y-py;
    if(dx*dx+dy*dy<900){
      if(p.type==='power'){
        G.power=Math.min(K.MAX_POW,G.power+20);
        if(Math.floor(G.power/80)>oldPow){showMsg('POWER UP',1200);Sfx.powerup();}
        if(G.power===K.MAX_POW&&oldPow<Math.floor(K.MAX_POW/80)){showMsg('MAX POWER',1800);Sfx.powerMax();}
      }else if(p.type==='bomb'){
        const maxB=DIFF[cfg.difficulty].maxBomb;
        if(G.bombs<maxB){G.bombs++;showMsg('BOMB GET',1400);Sfx.powerup();}
        else{G.score+=500;if(cfg.scorePop)popScore(p.x,p.y,500,1);}
      }else{
        G.extendCount=(G.extendCount||0)+1;
        if(G.extendCount>=K.EXTEND_NEED){G.extendCount=0;G.life++;showMsg('EXTEND!',2000);Sfx.extend();shake(6,12);}
        else{showMsg('ITEM  '+G.extendCount+' / '+K.EXTEND_NEED,1300);Sfx.powerup();}
      }
      G.pus.splice(i,1);
    }
  }
}

function onHit(){
  G.deathbombF=K.DEATHBOMB_F;
  G.life--;G.invuln=K.INVULN;
  const powLoss=G.power>=80?80:G.power;
  G.power=Math.max(0,G.power-powLoss);
  G.combo=0;G.comboF=0;shake(8,16);G.flashA=.38;Sfx.hit();
  inp.slow=false;
  if(G.life<=0){gameDead();return;}
  if(G.boss&&G.boss.spellPhase&&!G.boss.spellFailed){G.boss.spellFailed=true;G.spellBonus=0;showMsg('SPELL FAILED',1000);}
}

function useBomb(isDeathBomb){
  if(G.bombs<=0||G.bombCD>0||G.state!=='play')return;
  const focus=!isDeathBomb&&inp.slow;
  G.bombs--;G.bombCD=isDeathBomb?K.BOMB_INV:K.BOMB_F;
  if(focus){
    const cx=G.px+12,cy=G.py+12,rad=230;let cnt=0;
    for(const b of G.eB){if(b.dead)continue;const dx=b.x-cx,dy=b.y-cy;if(dx*dx+dy*dy<rad*rad){G.convertPts.push({x:b.x,y:b.y,life:32});b.dead=true;cnt++;}}
    if(cnt>0){const pts=300*cnt;G.score+=pts;if(cfg.scorePop)popScore(cx,cy-30,pts,1);Sfx.convert();}
    spawnParts(cx,cy,'rgba(255,120,200,.95)',28,5,34);
  }else{
    convertBullets();
    spawnParts(G.px+12,G.py+12,'rgba(255,220,80,.9)',30,5.5,38);
  }
  for(let i=G.ens.length-1;i>=0;i--){
    const e=G.ens[i];
    spawnParts(e.x+e.w/2,e.y+e.h/2,e.pals[0].ball,8,3,20);
    spawnRing(e.x+e.w/2,e.y+e.h/2,e.pals[0].ball);
    const bd=focus?30:22;e.hp-=bd;if(e.hp<=0){G.killed++;G.ens.splice(i,1);}
  }
  if(G.boss){G.boss.hp-=isDeathBomb?100:(focus?150:120);if(G.boss.hp<=0)bossDown();}
  G.invuln=isDeathBomb?K.BOMB_INV:200;G.flashA=.42;shake(focus?10:14,focus?18:24);
  showMsg(isDeathBomb?'DEATHBOMB':(focus?'集中ボム':'BOMB'),1200);Sfx.bomb();
}

function bossDown(){
  const b=G.boss;
  if(b.spellPhase&&!b.spellFailed&&G.spellBonus>0){
    G.totalSpellBonus+=G.spellBonus;G.score+=G.spellBonus;
    if(cfg.scorePop)popScore(W/2,H*.35,G.spellBonus,1);
    showMsg('SPELL BONUS! +'+G.spellBonus.toLocaleString(),2000);Sfx.spellBonus();
  }
  G.score+=b.sc;
  const bx=b.x+b.w/2,by=b.y+b.h/2;
  spawnParts(bx,by,PALETTE.white.ball,50,5.5,50);
  for(let i=0;i<6;i++)setTimeout(()=>spawnRing(bx,by,PALETTE[PAL_KEYS[i]].ball),i*65);
  shake(20,30);G.flashA=.5;Sfx.bigBang();
  convertBullets();
  G.pus.push({x:bx,y:by,type:'extend',t:0});
  G.boss=null;bRetAll(G.eB);
  $('spell-timer-bar').style.display='none';
  $('hud-boss-area').style.display='none';
  stageClear();
}

function stageClear(){
  G.state='clear';G.clearF=0;
  const bonus=G.life*300+G.graze*3;G.score+=bonus;
  showMsg('CLEAR  +'+bonus.toLocaleString(),9999);Sfx.clear();
  const d=DIFF[cfg.difficulty];
  if(d.recover&&G.life<d.life)G.life=Math.min(d.life,G.life+1);
}

function finishClear(){
  G.msg={t:'',f:0};
  if(G.stage>=K.MAX_STAGE){gameComplete();return;}
  G.stage++;G.stageF=0;G.diffMult=1+(G.stage-1)*DIFF[cfg.difficulty].growth;
  G.formF=60;
  showBanner('STAGE '+G.stage);G.state='countdown';
  startCountdown(()=>{G.state='play';});
}

function gameDead(){G.state='dead';teardown();const acc=G.spawned?Math.round(G.killed/G.spawned*100):0;showResult('GAME OVER','red',grade(acc),acc);refreshSysBar();}
function gameComplete(){G.state='dead';teardown();const acc=G.spawned?Math.round(G.killed/G.spawned*100):0;showResult('ALL CLEAR','grn','S',acc);refreshSysBar();}
function grade(acc){const s=acc+G.stage*20+G.maxCombo*2+Math.floor(G.graze/8)+Math.floor(G.totalSpellBonus/5000);return s>=180?'S':s>=140?'A':s>=100?'B':s>=65?'C':'D';}
function showResult(title,cls,gr,acc){
  hs=Store.addHS(hs,{score:G.score,stage:G.stage,combo:G.maxCombo,graze:G.graze,acc});
  $('r-title').textContent=title;$('r-title').className=cls;$('r-grade').textContent=gr;
  $('r-score').textContent=G.score.toLocaleString();$('r-stage').textContent=G.stage;
  $('r-combo').textContent=G.maxCombo;$('r-graze').textContent=G.graze;
  $('r-spell').textContent=G.totalSpellBonus.toLocaleString();
  $('r-acc').textContent=acc+'%';
  show('o-result');
}

function startCountdown(cb){
  const ov=$('o-count'),num=$('count-num');ov.style.display='flex';
  let n=3;
  function tick(){
    num.classList.remove('show','go');void num.offsetWidth;
    num.textContent=n>0?String(n):'GO';num.classList.add('show');
    if(n===0)num.classList.add('go');
    if(n>0)Sfx.countdown();else Sfx.go();
    n--;if(n>=-1)setTimeout(tick,700);else{ov.style.display='none';cb();}
  }
  tick();
}

/* ====== HUD更新関数（DOM） ====== */
function updateHUD(){
  // Score
  $('hud-score').textContent=G.score.toLocaleString();
  // Hiscore
  const topScore=hs.length?hs[0].score:0;
